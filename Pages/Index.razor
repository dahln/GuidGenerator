@page "/"
@inject IToastService toastService
@inject IJSRuntime JSRuntime

<div class="row">
    <nav class="navbar bg-body-tertiary">
        <div class="container-fluid">
            <a class="navbar-brand" href="#">
                Guid Generator
            </a>
            <a href="https://github.com/dahln/GuidGenerator" target="_blank">
                <i class="fa-brands fa-github float-end fa-2x me-2"></i>
            </a>
        </div>
    </nav>
</div>

<div class="row mt-5">
    <div class="col-lg-12 text-center">
        <span class="header">Guid Generator</span>
    </div>
</div>


<div class="row mt-5">
    <div class="col-12 col-lg-6 offset-lg-3 px-3 px-lg-5 pt-3 pb-0">
        <div class="input-group input-group-lg mb-3">
            <input type="text" class="form-control guid-input" @bind="GeneratedGuid" readonly />
            <button class="btn btn-primary" type="button" @onclick="GenerateGuid" title="Generate">
                Generate &amp; Copy
            </button>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(GeneratedGuid))
{
    <div class="row mt-4">
        <div class="col-12 col-lg-6 offset-lg-3 px-3 px-lg-5">
            <div class="guid-string-section p-3">
                <p class="guid-string-label mb-2">UUID v5 (Derived from GUID String Using SHA-1)</p>
                <p class="guid-string-value mb-0">@GuidStringGuid</p>
            </div>
        </div>
    </div>
}

@code {

    private string? GeneratedGuid { get; set; }
    private string? GuidStringGuid { get; set; }

    private async Task GenerateGuid()
    {
        GeneratedGuid = Guid.NewGuid().ToString().ToUpper();
        GuidStringGuid = GenerateVersion5Guid(GeneratedGuid).ToString().ToUpper();
        await CopyGuid();
    }

    private async Task CopyGuid()
    {
        await JSRuntime.InvokeVoidAsync("clipboardCopy.copyText", GeneratedGuid);
        toastService.ShowSuccess("Copied");
    }

    // UUID v5: deterministic GUID derived from the GUID string using SHA-1
    private static readonly Guid UuidV5UrlNamespace = new Guid("6ba7b811-9dad-11d1-80b4-00c04fd430c8");

    private static Guid GenerateVersion5Guid(string name)
    {
        var namespaceBytes = UuidV5UrlNamespace.ToByteArray();
        SwapByteOrder(namespaceBytes);

        var nameBytes = System.Text.Encoding.UTF8.GetBytes(name);

        byte[] hash;
        using (var sha1 = System.Security.Cryptography.SHA1.Create())
        {
            sha1.TransformBlock(namespaceBytes, 0, namespaceBytes.Length, null, 0);
            sha1.TransformFinalBlock(nameBytes, 0, nameBytes.Length);
            hash = sha1.Hash!;
        }

        var guidBytes = new byte[16];
        Array.Copy(hash, 0, guidBytes, 0, 16);

        // Set version 5
        guidBytes[6] = (byte)((guidBytes[6] & 0x0F) | 0x50);
        // Set variant
        guidBytes[8] = (byte)((guidBytes[8] & 0x3F) | 0x80);

        SwapByteOrder(guidBytes);
        return new Guid(guidBytes);
    }

    private static void SwapByteOrder(byte[] guid)
    {
        (guid[0], guid[3]) = (guid[3], guid[0]);
        (guid[1], guid[2]) = (guid[2], guid[1]);
        (guid[4], guid[5]) = (guid[5], guid[4]);
        (guid[6], guid[7]) = (guid[7], guid[6]);
    }

}
